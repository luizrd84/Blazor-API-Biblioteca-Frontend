<div class="subtitulo">
    <h2>Busca por Ano</h2>
</div>

<div class="form-container">
    <EditForm Model="@buscaPorAno" OnValidSubmit="PesquisaPorAno">
        <label class="text-muted mt-3">Ano</label>
        <InputNumber TValue="int" @bind-Value=buscaPorAno class="form-control" name="Ano"></InputNumber>
        <button type="submit" class="mt-3 btn btn-primary">Pesquisar</button>
    </EditForm>
</div>

@if (livrosByAno.Count > 0) {
    <div class="exibir-tabela">
        <QuickGrid Items="livrosByAno.AsQueryable()" TGridItem="Livro" Pagination="paginacaoGetByAno" class="table">
