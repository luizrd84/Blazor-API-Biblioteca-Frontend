@page "/livros"
@using Microsoft.AspNetCore.Components.QuickGrid
@using _03Blazor_Biblioteca.src.Components
@using src.Models
@rendermode InteractiveServer
@inject IHttpClientFactory factory
@using System.Text.Json



<div class="titulo">
    <h1>Livros</h1>
</div>


<div class="subtitulo">
    <h2>Lista com todos os Livros cadastradas</h2>
</div>

<div class="exibir-tabela">
    <QuickGrid Items="livros.AsQueryable()" TGridItem="Livro" Pagination="paginacao" class="table">
        <PropertyColumn Property="@(l => l.Id)" Title="Id" />
        <TemplateColumn Title="Título">
            <span class="texto-cortado" title="@context.Titulo">
                @context.Titulo
            </span>
        </TemplateColumn>

        <PropertyColumn Property="@(l => autoresDicionario[l.Autor_id].Nome)" Title="Autor" />   
            
        <PropertyColumn Property="@(l => editorasDicionario[l.Editora_id].Nome)" Title="Editora" />

        <PropertyColumn Property="@(l => l.ano)" Title="Ano Lançamento" />     
        <TemplateColumn Title="Ações">
            <button class="btn btn-sm btn-primary" @onclick="() => Editar(context)">
                Editar
            </button>
            <button class="btn btn-sm btn-danger" @onclick="() => Excluir(context)">
                Excluir
            </button>
        </TemplateColumn>
    </QuickGrid>
    <Paginator State="paginacao" />
</div>


@if (exibirPainelInicial) {
    <div class="acessar-cadastro">
        <h3>Para cadastrar um novo livro, clique abaixo:</h3>
        <button class="mt-3 btn btn-primary" @onclick="ExibirPainelCadastro">
            Cadastrar Livro
        </button>        
    </div>
}

@if (exibirPainelCadastro) {
    <div class="form-container">

        <div class="subtitulo">
            <h2>@menuInclusaoTitulo</h2>          
        </div>

        <EditForm Model="@livroAtual" OnValidSubmit="Confirmar" OnInvalidSubmit="TratarErros">
            <DataAnnotationsValidator /> 
            <label class="text-muted mt-2">Título</label>
            <InputText @bind-Value=livroAtual.Titulo class="form-control" name="titulo"></InputText>
            <ValidationMessage For="@(() => livroAtual.Titulo)" />           
     
            <label class="text-muted mt-2">Autor</label>
            <InputSelect class="form-control" @bind-Value="livroAtual.Autor_id">                
                @foreach (var autor in autoresDicionario)                {
                    <option value="@autor.Value.Id">@autor.Value.Nome</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => livroAtual.Autor_id)" />

            <label class="text-muted mt-2">Editora</label>
            <InputSelect class="form-control" @bind-Value="livroAtual.Editora_id">       
                @foreach (var editora in editorasDicionario)                {
                    <option value="@editora.Value.Id">@editora.Value.Nome</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => livroAtual.Autor_id)" />

            <label class="text-muted mt-2">Ano</label>
            <InputNumber TValue="int" @bind-Value=livroAtual.ano class="form-control" name="ano"></InputNumber>
            <ValidationMessage For="@(() => livroAtual.ano)" />           
            <button type="submit" class="mt-3 btn btn-primary" >
                @menuInclusaoBotao
            </button>
        </EditForm>
    </div>
}

<div class="subtitulo">
    <h2>Busca por Titulo</h2>
</div>

<div class="form-container">
    <EditForm Model="@buscaPorTitulo" OnValidSubmit="PesquisaPorTitulo">
        <label class="text-muted mt-3">Título</label>
        <InputText @bind-Value=buscaPorTitulo class="form-control" name="Titulo"></InputText>
        <button type="submit" class="mt-3 btn btn-primary">Pesquisar</button>
    </EditForm>
</div>

@if(livrosByTitulo.Count > 0) {
    <div class="exibir-tabela">
        <QuickGrid Items="livrosByTitulo.AsQueryable()" TGridItem="Livro" Pagination="paginacaoGetByTitulo" class="table">            
            <PropertyColumn Property="@(l => l.Id)" Title="Id" />
            <TemplateColumn Title="Título">
                <span class="texto-cortado" title="@context.Titulo">
                    @context.Titulo
                </span>
            </TemplateColumn>
            <PropertyColumn Property="@(l => autoresDicionario[l.Autor_id].Nome)" Title="Autor" />            
            <PropertyColumn Property="@(l => editorasDicionario[l.Editora_id].Nome)" Title="Editora" />
            <PropertyColumn Property="@(l => l.ano)" Title="Ano Lançamento" />                    
        </QuickGrid>
        <Paginator State="paginacaoGetByTitulo" />
    </div>
}


<div class="subtitulo">
